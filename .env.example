# Copy to .env and fill in values.

# App login (required to use the UI and API)
APP_LOGIN_USER=admin
APP_LOGIN_PASSWORD=change-this-password

# Sign session cookies (use a long random string, e.g. openssl rand -hex 32)
SESSION_SECRET=replace-with-random-32-plus-chars

# Optional: force Secure cookie on HTTPS even if NODE_ENV is not production
# FORCE_SECURE_COOKIE=1

# Server (Render injects PORT automatically)
# PORT=3000

# --- Render.com ---
# Di dashboard Render set juga: NODE_ENV=production, FORCE_SECURE_COOKIE=1
# Lihat render.yaml dan deploy-render.txt untuk langkah deploy.

# Optional: Google Calendar API Key for live Indonesian public holidays
# Get from: https://console.cloud.google.com → Enable "Google Calendar API" → Create API Key
# If not set, the app will use a built-in hardcoded holiday list as fallback.
# GOOGLE_CALENDAR_API_KEY=AIza...
